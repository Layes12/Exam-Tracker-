rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.email is string
                    && request.resource.data.coins is int
                    && request.resource.data.level is int;
      allow update: if isOwner(userId)
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.email == resource.data.email;
      allow delete: if false; 

      match /chapters/{chapterId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && isValidId(chapterId)
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.subject is string
                      && request.resource.data.chapterName is string;
        allow update: if isOwner(userId)
                      && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId);
      }

      match /routines/{routineId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && isValidId(routineId)
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.dayIndex is int;
        allow update: if isOwner(userId)
                      && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId);
      }

      match /sessionLogs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && isValidId(logId)
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.chapterId is string
                      && request.resource.data.durationMinutes is int;
        allow update: if isOwner(userId)
                      && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId);
      }
    }
  }
}
